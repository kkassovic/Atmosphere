# Atmosphere Configuration

# API Server
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_PATH=/opt/atmosphere/atmosphere.db

# Storage Directories
WORKSPACES_DIR=/opt/atmosphere/workspaces
KEYS_DIR=/opt/atmosphere/keys
LOGS_DIR=/opt/atmosphere/logs

# LOGS_DIR can point to different backup storage:
# 1. Local filesystem (default):
#    LOGS_DIR=/opt/atmosphere/logs
#
# 2. Mounted CIFS/SMB network share:
#    LOGS_DIR=/mnt/atmosphere-backups
#
# 3. Mounted USB drive:
#    LOGS_DIR=/mnt/usb-backup
#
# See docs/BACKUP_STORAGE_OPTIONS.md for setup instructions

# Docker
DOCKER_NETWORK=atmosphere
TRAEFIK_NETWORK=traefik

# Domain (optional - for default routing)
# DOMAIN=example.com

# Let's Encrypt
LETSENCRYPT_EMAIL=admin@example.com

# Traefik
TRAEFIK_DASHBOARD=false
TRAEFIK_DASHBOARD_DOMAIN=traefik.example.com

# S3 Backup Storage (optional)
# Leave all S3 variables empty to use local filesystem backups (default)
# 
# Supports three backup storage options:
# 1. S3 (DigitalOcean Spaces, AWS S3, MinIO)
# 2. CIFS/SMB (NAS, network shares) - use mounted LOGS_DIR above
# 3. USB Drive (external storage) - use mounted LOGS_DIR above
#
# For S3 storage, configure:
S3_ENDPOINT=https://nyc3.digitaloceanspaces.com
S3_BUCKET=my-backups-bucket
S3_REGION=nyc3
S3_ACCESS_KEY=your-access-key-here
S3_SECRET_KEY=your-secret-key-here
S3_PATH_PREFIX=atmosphere-backups
#
# For detailed setup instructions, see docs/BACKUP_STORAGE_OPTIONS.md

{
  "id": "netdata",
  "name": "Netdata",
  "description": "Real-time performance monitoring dashboard",
  "deployment_type": "manual",
  "build_type": "compose",
  "compose_path": "docker-compose.yml",
  "port": 19999,
  "inputs": [
    {
      "name": "tz",
      "label": "Timezone",
      "type": "string",
      "required": false,
      "default": "UTC"
    }
  ],
  "default_env": {
    "TZ": "{{tz}}"
  },
  "metadata": {
    "category": "monitoring",
    "sample_provision_curl": "curl -X POST http://localhost:3000/api/v1/templates/netdata/provision -H \"Content-Type: application/json\" -d '{\"app_name\":\"my-netdata\",\"domains\":[\"metrics.example.com\"],\"inputs\":{\"tz\":\"UTC\"},\"env_vars\":{},\"auto_deploy\":true}'"
  }
}

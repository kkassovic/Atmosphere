{
  "id": "superset",
  "name": "Apache Superset",
  "description": "Business intelligence and data visualization platform",
  "deployment_type": "manual",
  "build_type": "compose",
  "compose_path": "docker-compose.yml",
  "port": 8088,
  "inputs": [
    {
      "name": "secret_key",
      "label": "Superset Secret Key",
      "type": "secret",
      "required": true
    }
  ],
  "default_env": {
    "SUPERSET_SECRET_KEY": "{{secret_key}}"
  },
  "metadata": {
    "category": "analytics",
    "sample_provision_curl": "curl -X POST http://localhost:3000/api/v1/templates/superset/provision -H \"Content-Type: application/json\" -d '{\"app_name\":\"my-superset\",\"domains\":[\"superset.example.com\"],\"inputs\":{\"secret_key\":\"change-me-secret-key\"},\"env_vars\":{},\"auto_deploy\":true}'"
  }
}

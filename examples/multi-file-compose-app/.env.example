# Environment variables template for production

# These are automatically injected by Atmosphere:
# ATMOSPHERE_APP=multi-file-app
# DOMAIN=app.yourdomain.com
# TRAEFIK_NETWORK=traefik

# Application settings
APP_NAME=multi-file-app
APP_ENV=production
DEBUG=false
LOG_LEVEL=info

# Resource limits (optional, adjust based on server)
CONTAINER_CPU_LIMIT=0.9
CONTAINER_MEMORY_LIMIT=1G
CONTAINER_CPU_RESERVATION=0.25
CONTAINER_MEMORY_RESERVATION=256M

# Add your custom variables here
SECRET_KEY=change_me_in_production

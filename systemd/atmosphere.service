[Unit]
Description=Atmosphere Deployment Platform
After=docker.service
Requires=docker.service

[Service]
Type=simple
User=root
WorkingDirectory=/opt/atmosphere
EnvironmentFile=/opt/atmosphere/.env
ExecStart=/opt/atmosphere/atmosphere
Restart=always
RestartSec=10

# Security settings
NoNewPrivileges=true
PrivateTmp=true

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=atmosphere

[Install]
WantedBy=multi-user.target
